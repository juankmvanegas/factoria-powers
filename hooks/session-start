#!/usr/bin/env bash
# SessionStart hook for factoria plugin
# Detects the active factory and injects the using-factoria bootstrap.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
CWD="${PWD}"

# ---------------------------------------------------------------------------
# Factory auto-detection (ported from bin/factoria-init.mjs)
# ---------------------------------------------------------------------------

detect_factory() {
  local dir="$1"

  # .NET: .sln / .csproj / Program.cs
  local is_net=0
  if ls "$dir"/*.sln 2>/dev/null | grep -q . || \
     ls "$dir"/*.csproj 2>/dev/null | grep -q . || \
     [ -f "$dir/Program.cs" ]; then
    is_net=1
  fi

  # Read package.json deps once
  local has_angular=0 has_nest=0
  if [ -f "$dir/package.json" ]; then
    if grep -qs '"@angular/core"' "$dir/package.json"; then has_angular=1; fi
    if grep -qs '"@nestjs/core"' "$dir/package.json"; then has_nest=1; fi
  fi

  # .NET + Angular = fullstack
  if [ "$is_net" -eq 1 ] && ([ -f "$dir/angular.json" ] || [ "$has_angular" -eq 1 ]); then
    echo "both"
    return
  fi

  if [ "$is_net" -eq 1 ]; then
    echo "net"
    return
  fi

  # DataEng: databricks.yml / dlt.yml / pyspark / delta-spark
  if [ -f "$dir/databricks.yml" ] || [ -f "$dir/dlt.yml" ] || \
     grep -qs "pyspark\|delta-spark" "$dir/pyproject.toml" 2>/dev/null || \
     grep -qs "pyspark\|delta-spark" "$dir/requirements.txt" 2>/dev/null; then
    echo "dataeng"
    return
  fi

  # Python MLOps: dvc.yaml / mlflow / dvc[azure]
  if [ -f "$dir/dvc.yaml" ] || \
     grep -qs "mlflow\|dvc\[azure\]" "$dir/pyproject.toml" 2>/dev/null; then
    echo "pytml"
    return
  fi

  # Python FastAPI: main.py / fastapi dep
  if [ -f "$dir/main.py" ] || \
     grep -qs "fastapi" "$dir/pyproject.toml" 2>/dev/null || \
     grep -qs "fastapi" "$dir/requirements.txt" 2>/dev/null || \
     grep -qs "fastapi" "$dir/requirements-dev.txt" 2>/dev/null; then
    echo "pyt"
    return
  fi

  # NestJS
  if [ "$has_nest" -eq 1 ]; then
    echo "nest"
    return
  fi

  # Angular: angular.json or @angular/core dep
  if [ -f "$dir/angular.json" ] || [ "$has_angular" -eq 1 ]; then
    echo "ang"
    return
  fi

  # iOS/Swift: .swift files / Package.swift / .xcodeproj
  if ls "$dir"/*.swift 2>/dev/null | grep -q . || \
     [ -f "$dir/Package.swift" ] || \
     ls "$dir"/*.xcodeproj 2>/dev/null | grep -q . || \
     ls "$dir"/*.xcworkspace 2>/dev/null | grep -q .; then
    echo "swf"
    return
  fi

  # WordPress Block Theme: theme.json + functions.php + style.css, or wp-content/
  if ([ -f "$dir/theme.json" ] && [ -f "$dir/functions.php" ] && [ -f "$dir/style.css" ]) || \
     [ -d "$dir/wp-content" ]; then
    echo "wps"
    return
  fi

  # Android/Kotlin: build.gradle.kts / *.kt / AndroidManifest.xml
  if [ -f "$dir/build.gradle.kts" ] || \
     ls "$dir"/*.kt 2>/dev/null | grep -q . || \
     find "$dir" -maxdepth 3 -name "AndroidManifest.xml" 2>/dev/null | grep -q .; then
    echo "kot"
    return
  fi

  echo "unknown"
}

FACTORY=$(detect_factory "$CWD")

# ---------------------------------------------------------------------------
# Build context message
# ---------------------------------------------------------------------------

using_factoria_content=$(cat "${PLUGIN_ROOT}/skills/using-factoria/SKILL.md" 2>&1 || echo "Error reading using-factoria skill")

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

using_factoria_escaped=$(escape_for_json "$using_factoria_content")

if [ "$FACTORY" = "unknown" ]; then
  factory_header="Factory not auto-detected. Ask the user which factory applies (net | ang | nest | pyt | pytml | dataeng | kot | swf | wps), then invoke skill 'factoria:selecting-factory'."
elif [ "$FACTORY" = "both" ]; then
  factory_header="Detected multi-factory project (.NET + Angular). Active references: references/net/ and references/ang/. Ask the user which context is active for this session, or load both via skill 'factoria:loading-factory-context'."
else
  factory_header="Detected factory: ${FACTORY}. References at: references/${FACTORY}/. Load full context with skill 'factoria:loading-factory-context'."
fi

factory_header_escaped=$(escape_for_json "$factory_header")

session_context="<EXTREMELY_IMPORTANT>\nYou have Factoria.\n\n${factory_header_escaped}\n\n**Below is the full content of your 'factoria:using-factoria' skill — your introduction to Factoria. For all other skills, use the 'Skill' tool:**\n\n${using_factoria_escaped}\n</EXTREMELY_IMPORTANT>"

# ---------------------------------------------------------------------------
# Output correct JSON shape per host CLI
# Uses printf instead of heredoc to avoid bash 5.3+ heredoc hang.
# ---------------------------------------------------------------------------

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  # Cursor sets CURSOR_PLUGIN_ROOT
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  # Claude Code sets CLAUDE_PLUGIN_ROOT without COPILOT_CLI
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  # Copilot CLI (COPILOT_CLI=1) or unknown platform — SDK standard format
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
